<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/onboarding_background"
    tools:context=".StudentIdPhotoActivity">

    <ImageButton
        android:id="@+id/studentIdBackButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back"
        android:padding="10dp"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/login_purple" />

    <ImageView
        android:id="@+id/studentIdLogo"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/app_name"
        app:layout_constraintBottom_toTopOf="@+id/studentIdTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:srcCompat="@drawable/goodlogo" />

    <TextView
        android:id="@+id/studentIdTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="48dp"
        android:gravity="center"
        android:text="@string/student_id_photo"
        android:textColor="@color/onboarding_text"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/studentIdSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/studentIdLogo" />

    <TextView
        android:id="@+id/studentIdSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="48dp"
        android:gravity="center"
        android:text="@string/student_id_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/studentIdHint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/studentIdTitle" />

    <TextView
        android:id="@+id/studentIdHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="22dp"
        android:layout_marginEnd="48dp"
        android:gravity="center"
        android:text="@string/student_id_hint"
        android:textColor="@color/accent_pink_dark"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/photoPlaceholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/studentIdSubtitle" />

    <FrameLayout
        android:id="@+id/photoPlaceholder"
        android:layout_width="156dp"
        android:layout_height="108dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/student_id_placeholder_background"
        app:layout_constraintBottom_toTopOf="@+id/photoStatusText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/studentIdHint">

        <ImageView
            android:id="@+id/studentIdCardIcon"
            android:layout_width="86dp"
            android:layout_height="58dp"
            android:layout_gravity="center"
            android:contentDescription="@string/student_id_photo"
            android:scaleType="centerInside"
            android:src="@drawable/ic_student_card" />
    </FrameLayout>

    <TextView
        android:id="@+id/photoStatusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="48dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@+id/photoErrorText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/photoPlaceholder" />

    <TextView
        android:id="@+id/photoErrorText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="48dp"
        android:gravity="center"
        android:minHeight="18dp"
        android:textColor="@color/error_red"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/uploadPhotoButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/photoStatusText" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/uploadPhotoButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="48dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="48dp"
        android:background="@drawable/button_gradient"
        android:text="@string/upload_photo"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:cornerRadius="8dp"
        app:elevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/takePhotoButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/photoErrorText" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/takePhotoButton"
        style="@style/Widget.StudentDealz.SignUpChoiceButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="48dp"
        android:text="@string/take_photo"
        android:textColor="@color/accent_pink_dark"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/uploadPhotoButton"
        app:strokeColor="@color/accent_pink_dark" />
</androidx.constraintlayout.widget.ConstraintLayout>
